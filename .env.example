# Jira (Atlassian Cloud)
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=you@company.com
JIRA_AUTH_TOKEN=your_jira_api_token

# GitHub (choose ONE auth mode)
# Option A: GitHub App (recommended for org-scale)
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_INSTALLATION_ID=

# Option B: Personal Access Token (PAT)
GITHUB_PAT=

# AWS
AWS_REGION=us-east-1
# Optional: assume a role for cross-account access (source credentials must already be available in the runtime)
AWS_ROLE_ARN=

# Nexus runtime
NEXUS_TRANSPORT=stdio
NEXUS_HOST=0.0.0.0
NEXUS_PORT=8787
# Optional: public base URL used to construct the SSE message endpoint (behind ALB/API GW)
NEXUS_PUBLIC_BASE_URL=

